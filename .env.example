# JalDrishti — Backend Configuration
# Copy this file to .env and fill in your values

# ─── LLM Configuration ───
# Provider: openai | anthropic | gemini
# Default: anthropic (Claude)
LLM_PROVIDER=anthropic
# Get your API key from:
# Anthropic: https://console.anthropic.com/account/keys
# OpenAI: https://platform.openai.com/account/api-keys
# Google Gemini: https://makersuite.google.com/app/apikey
LLM_API_KEY=
# If empty, chatbot will use rule-based responses (no API calls)

# ─── Data ───
CSV_PATH=india_research_full.csv

# ─── Server ───
PORT=5000
DEBUG=true
SECRET_KEY=jaldrishti-secret-key-change-in-production

# ─── Report Output ───
REPORT_DIR=reports

# ─── Google Earth Engine ───
# PRIMARY satellite data source for water quality indices.
# GEE_PROJECT: Your Google Cloud project ID (with Earth Engine API enabled)
# Enable API at: https://console.cloud.google.com/apis/library/earthengine.googleapis.com
# Authentication: earthengine authenticate  (runs once via CLI)
# Docs: https://developers.google.com/earth-engine/guides/python_install
# GEE is free for research and handles Sentinel-2 at 10-20m resolution.
# No API key needed in .env — use local authentication via CLI.
GEE_PROJECT=

# ─── NASA OceanColor (Fallback) ───
# Used when GEE is unavailable.
# Get API key from: https://urs.earthdata.nasa.gov/
NASA_APPKEY=
